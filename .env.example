# Copy this file to .env and adjust values as needed
# .env is gitignored — never commit real credentials

# Required on Linux to avoid volume permission issues
# Run: echo "AIRFLOW_UID=$(id -u)" >> .env
AIRFLOW_UID=50000

# PostgreSQL superuser (used only for init_db.sh)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Olist data warehouse credentials (created by init_db.sh)
OLIST_DB_USER=olist
OLIST_DB_PASSWORD=olist
OLIST_DB_NAME=olist

# Airflow metadata DB credentials (created by init_db.sh)
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow
